# =====================================================================
# Great Energy Field — BACKEND (FastAPI) environment
# Copy to `backend/.env` and fill in. NEVER commit real secrets.
# =====================================================================

# ---------- App ----------
APP_ENV=local
LOG_LEVEL=info

# ---------- Database (PostgreSQL + pgvector; self-hosted / Docker) ----------
# Async driver used by the app engine.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/great_energy_field
# Sync driver used by Alembic migrations.
DATABASE_URL_SYNC=postgresql+psycopg://postgres:postgres@localhost:5432/great_energy_field

# ---------- Auth (FastAPI-native JWT; no external auth provider) ----------
# Generate a strong secret, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=dev-insecure-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---------- CORS ----------
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000

# ---------- AI provider (added in Week 4; placeholder now) ----------
AI_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---------- Payments (added in Week 5; placeholder now) ----------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# ---------- Web3 / Crypto (added in Week 5; placeholder now) ----------
BSC_RPC_URL=https://bsc-dataseed.binance.org
USDT_CONTRACT_ADDRESS=
USDC_CONTRACT_ADDRESS=
PAYMENT_RECEIVER_ADDRESS=
